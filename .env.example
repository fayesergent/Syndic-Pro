# ═══════════════════════════════════════════════════════════════
# SyndicPro — Variables d'environnement
# ═══════════════════════════════════════════════════════════════
#
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez les valeurs depuis votre dashboard Supabase :
#    https://app.supabase.com → Settings → API
#
# ⚠️  Ne committez JAMAIS le fichier .env dans Git
# ═══════════════════════════════════════════════════════════════

# URL de votre projet Supabase
# Exemple : https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Clé publique anonyme (safe pour le frontend)
# Dashboard Supabase → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=
